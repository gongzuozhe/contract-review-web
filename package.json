{
  "name": "contract-review-web",
  "version": "0.1.0",
  "private": true,
  "main": "electron.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron": "electron .",
    "dist": "npm run build && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.contractreview.app",
    "productName": "合同审查助手",
    "directories": {
      "output": "release"
    },
    "files": [
      ".next/standalone/**/*",
      ".next/static/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": ".next/standalone/server.js"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
    "file-saver": "^2.0.5",
    "lucide-react": "^0.441.0",
    "mammoth": "^1.12.0",
    "next": "14.2.5",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
